      },
      "identity": {
        "name": "Worker",
        "description": "You are a Worker agent in a multi-agent Discord group. Your responsibilities:\n\n1. RECEIVE: You will be @mentioned by the Leader agent (<@LEADER_BOT_ID>) with a specific task. Only act on tasks from Leader.\n2. EXECUTE: Complete the assigned task using your available tools (Bash, Read, Grep, etc.).\n3. REPORT: When done, reply in the group and include <@LEADER_BOT_ID> in your message so Leader is notified. Provide clear, structured results.\n4. STOP: After reporting, do NOT send any follow-up messages unless @mentioned again.\n\nRules:\n- Only respond when @mentioned. Never initiate conversations.\n- Always @mention Leader (<@LEADER_BOT_ID>) in your task completion reply.\n- Keep responses concise and data-focused.\n- If you cannot complete a task, @mention Leader and explain why.\n- Never @mention the human user directly; let Leader handle user communication."
      },
      "models": {
        "custom-integrate-api-nvidia-com/qwen/qwen3.5-397b-a17b": {
          "alias": "qwen3.5",
          "params": { "contextTokens": 128000 }
        },
        "custom-integrate-api-nvidia-com/z-ai/glm4.7": {
          "alias": "glm4.7",
          "params": { "contextTokens": 128000 }
        },
        "custom-integrate-api-nvidia-com/moonshotai/kimi-k2.5": {
          "alias": "kimi2.5",
          "params": { "contextTokens": 128000 }
        }
      },
      "workspace": "/home/liu/.openclaw/worker-workspace",
      "contextTokens": 64000,
      "contextPruning": {
        "mode": "cache-ttl",
        "ttl": "3m",
        "keepLastAssistants": 2,
        "softTrimRatio": 0.25,
        "hardClearRatio": 0.4,
        "minPrunableToolChars": 30000,
        "tools": { "allow": ["Bash", "Read", "Grep", "Glob"] },
        "softTrim": { "maxChars": 3000, "headChars": 1000, "tailChars": 1000 },
        "hardClear": { "enabled": true, "placeholder": "[Old content cleared]" }
      },
      "compaction": {
        "mode": "safeguard",
        "reserveTokensFloor": 10000,
        "maxHistoryShare": 0.3,
        "memoryFlush": { "enabled": true, "softThresholdTokens": 6000 }
